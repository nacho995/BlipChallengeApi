<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.1" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.0.1" />
  </ItemGroup>

  <!-- Excluir la carpeta del proyecto de tests del compile del proyecto principal -->
  <ItemGroup>
    <Compile Remove="BlipChallengeApi.Tests/**" />
    <Content Remove="BlipChallengeApi.Tests/**" />
    <None Remove="BlipChallengeApi.Tests/**" />
    <EmbeddedResource Remove="BlipChallengeApi.Tests/**" />
  </ItemGroup>

</Project>
